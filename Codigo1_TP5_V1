void processData(AsyncResult &aResult){
  if (!aResult.isResult()) // Se verifica que haya un resultado/valor existente
    return;

  if (aResult.isEvent()) // Se verifica si ocurrió un evento. Se muestra el UID de la tarea, un mensaje y un código que identifican el tipo de evento ocurrido
    Firebase.printf("Event task: %s, msg: %s, code: %d\n", aResult.uid().c_str(), aResult.eventLog().message().c_str(), aResult.eventLog().code());

  if (aResult.isDebug()) // Informa lo que hace la biblioteca si el resultado es positivo, no es un error
    Firebase.printf("Debug task: %s, msg: %s\n", aResult.uid().c_str(), aResult.debug().c_str());

  if (aResult.isError()) // Informa si hubo un error
    Firebase.printf("Error task: %s, msg: %s, code: %d\n", aResult.uid().c_str(), aResult.error().message().c_str(), aResult.error().code());

  if (aResult.available()) // Informa si Firebase devolvió información
    Firebase.printf("task: %s, payload: %s\n", aResult.uid().c_str(), aResult.c_str());
}
