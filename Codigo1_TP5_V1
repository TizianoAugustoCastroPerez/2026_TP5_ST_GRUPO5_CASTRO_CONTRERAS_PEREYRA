      uid = app.getUid().c_str(); // Se obtiene el UID, lo que sirve para actualizar las rutas

      // Actualizar la ruta principal, ahora tiene un valor definido
      databasePath = "/UsersData/" + uid + "/readings";

      // Se obtiene el Epoch time con la función getTime
      timestamp = obtenerTiempo();

