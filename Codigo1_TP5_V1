// Función que obtiene el Epoch time (tiempo pasado desde cierto momento específico)
unsigned long obtenerTiempo() {
  time_t ahora; // Se crea una variable llamada ahora del tipo time_t
  struct tm timeinfo; // Estructura que guarda la hora en año, meses, días, horas, minutos y segundos
  if (!getLocalTime(&timeinfo)) {
    return(0);
  } // Se verifica si el ESP32 conoce la hora y en ese caso la guarda en timeinfo, en resumen se usa para verificar que los tiempos estén sincronizados
  time(&ahora); // Ahora si, ya verificada la sincronización, se devuelve el valor de la hora en Epoch time
  return ahora;
} // Si no se obtiene el tiempo no devuelve nada

void setup(){
  Serial.begin(115200);

  // LED Y BOTONES
  pinMode(pin_LED, OUTPUT);
  pinMode(B1, INPUT);
  pinMode(B2, INPUT);

  // DHT
  dht.begin();

  // OLED
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);

  // WIFI
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  Serial.print("Connecting to WiFi ..");
  while (WiFi.status() != WL_CONNECTED) {
    Serial.print('.');
    delay(1000);
  }

  // TIEMPO
  configTime(3600, 0, ntpServer); // Se obtiene el tiempo real. Como en Firebase elegimos la zona horaria belga (UTC +1), usamos la misma acá, para eso el 3600, suma 1 hora

  // CLIENTE SSL
  ssl_client.setInsecure(); // Con esto no se verifica la conexión con Firebase, ya que sabemos que va a ser correcta, por lo que se ahorra tiempo
  ssl_client.setConnectionTimeout(1000); // Se le da 1 segundo de tiempo al ESP32 y a Firebase para conectarse, sino se conectan s reintenta
  ssl_client.setHandshakeTimeout(5); // Se le da 5 segundos a Firebase para que envíe la verificación que confirme que la conexión ESP32 y Firebase es segura
  // SI falla alguna de estas conexiones, al ser Timeouts, no se congela el código, se sigue ejecutando y se ignora esa lectura/medición

  // INICIOFIREBASE
  initializeApp(aClient, app, getAuth(user_auth), processData, "TareaAutenticación"); // Se inicia la aplicación de Firebase, lo último es un nombre de referencia
  app.getApp<RealtimeDatabase>(Database); // Se recibe la base de datos en tiempo real de Firebase
  Database.url(DATABASE_URL); // Se indica con la URL a que base de datos hay que conectarse
}

void loop(){

