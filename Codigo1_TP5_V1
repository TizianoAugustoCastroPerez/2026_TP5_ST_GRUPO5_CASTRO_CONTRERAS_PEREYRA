      parentPath= databasePath + "/" + String(timestamp);

      // Temperatura
      temperatura = dht.readTemperature();

      // Se crean primero 2 objetos, el primero con la ruta y el valor de la temperatura, y el segundo con la ruta y el valor del tiempo
      writer.create(obj1, tempPath, temperatura);
      writer.create(obj2, timePath, timestamp);
      writer.join(jsonData, 2, obj1, obj2); // Con .join unimos los objetos Json en una sola estructura

      Database.set<object_t>(aClient, parentPath, jsonData, processData, "enviarDatosAFirebase");
